<Window x:Class="CS2ChatTranslator.Overlay.HistorySettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Chat Translator - Settings"
        Width="500"
        Height="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="34"
                          ShadowDepth="8"
                          Direction="270"
                          Opacity="0.6"
                          Color="#000000"/>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="MinWidth" Value="86"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Background" Value="#FF2C2C2E"/>
            <Setter Property="Foreground" Value="#FFF5F5F7"/>
            <Setter Property="BorderBrush" Value="#665A5A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.78"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="HistorySwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8F5F5F7"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border x:Name="Track"
                                    Width="36" Height="20"
                                    HorizontalAlignment="Left"
                                    Background="#FF3A3A3C"
                                    CornerRadius="10">
                                <Ellipse x:Name="Knob"
                                         Width="16" Height="16"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="2,0,0,0"/>
                            </Border>
                            <ContentPresenter Grid.Column="1"
                                              Margin="8,0,0,0"
                                              VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="#FF30D158"/>
                                <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Knob" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Background" Value="#FF2C2C2E"/>
            <Setter Property="Foreground" Value="#FFF5F5F7"/>
            <Setter Property="BorderBrush" Value="#665A5A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFF5F5F7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemSurface" Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}" CornerRadius="6">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF3A3A3C"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF0A84FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid Margin="10,0,8,0">
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="&#x2304;" Foreground="#88EBEBF5" FontSize="13"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Margin="8,-3,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent" BorderThickness="0" Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom" AllowsTransparency="True" PopupAnimation="Fade">
                                <Border Background="#FF2C2C2E" BorderBrush="#665A5A5F" BorderThickness="1"
                                        CornerRadius="8" Padding="4" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer VerticalScrollBarVisibility="Hidden"><ItemsPresenter/></ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FF1C1C1E"
            BorderBrush="#665A5A5F"
            BorderThickness="1"
            CornerRadius="14"
            Effect="{StaticResource WindowShadow}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="54"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <Border Background="#F5222224"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="18,0">
                    <TextBlock Text="Settings"
                               Foreground="#FFF5F5F7"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="14"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button Content="&#x00D7;"
                            Width="28" Height="28"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Background="#FF3A3A3C"
                            Foreground="White"
                            FontSize="17"
                            Style="{StaticResource CircleButton}"
                            Click="CancelButton_Click"/>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Margin="22,20">
                <TextBlock Text="Chat history"
                           Foreground="#FFF5F5F7"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="13"
                           FontWeight="SemiBold"/>

                <CheckBox x:Name="HistoryEnabledCheckBox"
                          Content="Store parsed chat messages locally"
                          Foreground="#E8F5F5F7"
                          FontFamily="Segoe UI Variable Text, Segoe UI"
                          FontSize="12"
                          Style="{StaticResource HistorySwitch}"
                          Margin="0,15,0,0"
                          Checked="HistoryEnabled_Changed"
                          Unchecked="HistoryEnabled_Changed"/>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="180"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Retention"
                                   Foreground="#FFF5F5F7"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Favorites are retained until manually deleted."
                                   Foreground="#88EBEBF5"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="10"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                    <ComboBox x:Name="RetentionComboBox"
                              Grid.Column="1"
                              Height="34"
                              Padding="9,3"
                              Background="#FF2C2C2E"
                              Foreground="#FFF5F5F7"
                              BorderBrush="#665A5A5F"
                              BorderThickness="1"
                              FontFamily="Segoe UI Variable Text, Segoe UI"
                              FontSize="12"
                              Style="{StaticResource SettingsCombo}"/>
                </Grid>

                <Border Height="1" Background="#24FFFFFF" Margin="0,20,0,16"/>

                <TextBlock Text="Storage location"
                           Foreground="#FFF5F5F7"
                           FontFamily="Segoe UI Variable Text, Segoe UI"
                           FontSize="12"
                           FontWeight="SemiBold"/>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="DatabasePathText"
                               Foreground="#88EBEBF5"
                               FontFamily="Cascadia Mono, Consolas"
                               FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="1"
                            Content="Open folder"
                            Style="{StaticResource ActionButton}"
                            Margin="12,0,0,0"
                            Click="OpenFolderButton_Click"/>
                </Grid>
            </StackPanel>

            <Border Grid.Row="2"
                    Background="#F5222224"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,14,14">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="18,0">
                    <Button Content="Cancel"
                            Style="{StaticResource ActionButton}"
                            Click="CancelButton_Click"/>
                    <Button Content="Save"
                            Style="{StaticResource ActionButton}"
                            Background="#FF0A84FF"
                            BorderBrush="#FF0A84FF"
                            Margin="9,0,0,0"
                            Click="SaveButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
