<Window x:Class="CS2ChatTranslator.Overlay.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="CS2 Chat Translator - History"
        Width="1120"
        Height="720"
        MinWidth="900"
        MinHeight="580"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            CornerRadius="14"
                            GlassFrameThickness="0"
                            ResizeBorderThickness="6"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <DropShadowEffect x:Key="WindowShadow"
                          BlurRadius="38"
                          ShadowDepth="8"
                          Direction="270"
                          Opacity="0.6"
                          Color="#000000"/>

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#FF2C2C2E"/>
            <Setter Property="Foreground" Value="#FFF5F5F7"/>
            <Setter Property="BorderBrush" Value="#665A5A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Background" Value="#FF3A3A3C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.68"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.34"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CircleButton" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Surface"
                                Width="{TemplateBinding Width}"
                                Height="{TemplateBinding Height}"
                                Background="{TemplateBinding Background}"
                                CornerRadius="18">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Surface" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="104"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="Background" Value="#FF2C2C2E"/>
            <Setter Property="Foreground" Value="#FFF5F5F7"/>
            <Setter Property="BorderBrush" Value="#665A5A5F"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI Variable Text, Segoe UI"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#FFF5F5F7"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Padding" Value="10,7"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="ItemSurface"
                                            Background="{TemplateBinding Background}"
                                            Padding="{TemplateBinding Padding}"
                                            CornerRadius="6">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF3A3A3C"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemSurface" Property="Background" Value="#FF0A84FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboSurface"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid Margin="10,0,8,0">
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Text="&#x2304;"
                                               Foreground="#88EBEBF5"
                                               FontSize="13"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Margin="8,-3,0,0"/>
                                </Grid>
                            </Border>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="#FF2C2C2E"
                                        BorderBrush="#665A5A5F"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="260">
                                    <ScrollViewer VerticalScrollBarVisibility="Hidden">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#FF1C1C1E"
            BorderBrush="#665A5A5F"
            BorderThickness="1"
            CornerRadius="14"
            Effect="{StaticResource WindowShadow}">
        <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="52"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#F5222224"
                    BorderBrush="#24FFFFFF"
                    BorderThickness="0,0,0,1"
                    CornerRadius="14,14,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="16,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Width="13" Height="13" Margin="0,0,8,0"
                                Background="#FFFF5F57" Style="{StaticResource CircleButton}"
                                ToolTip="Close" Click="CloseWindow_Click"/>
                        <Button Width="13" Height="13" Margin="0,0,8,0"
                                Background="#FFFFBD2E" Style="{StaticResource CircleButton}"
                                ToolTip="Minimize" Click="MinimizeWindow_Click"/>
                        <Button Width="13" Height="13"
                                Background="#FF28C840" Style="{StaticResource CircleButton}"
                                ToolTip="Maximize" Click="MaximizeWindow_Click"/>
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               Text="CS2 Chat Translator"
                               Foreground="#FFF5F5F7"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="13"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="Chat History"
                               Foreground="#88EBEBF5"
                               FontFamily="Segoe UI Variable Text, Segoe UI"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="3"
                            Width="28" Height="28"
                            Margin="10,0,0,0"
                            Background="#FF3A3A3C"
                            Foreground="#B8EBEBF5"
                            FontSize="15"
                            Style="{StaticResource CircleButton}"
                            ToolTip="Settings"
                            Click="SettingsButton_Click"
                            Content="&#x2699;"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="244"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Background="#D9202022" Padding="14,16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Sessions"
                                   Foreground="#99EBEBF5"
                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Margin="8,0,0,10"/>

                        <ListBox x:Name="SessionList"
                                 Grid.Row="1"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 SelectionChanged="SessionList_SelectionChanged">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,3"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemSurface"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="8"
                                                        Padding="10,8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemSurface" Property="Background" Value="#663A3A3C"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemSurface" Property="Background" Value="#FF0A84FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding PrimaryText}"
                                                       Foreground="#FFF5F5F7"
                                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding SecondaryText}"
                                                       Foreground="#99EBEBF5"
                                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                                       FontSize="10"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CountText}"
                                                   Foreground="#99EBEBF5"
                                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="10"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Margin="0,12,0,0">
                            <Button Content="Export current view"
                                    Style="{StaticResource ToolbarButton}"
                                    Click="ExportButton_Click"/>
                            <Button Content="Clear history"
                                    Style="{StaticResource ToolbarButton}"
                                    Foreground="#FFFF6961"
                                    Margin="0,7,0,0"
                                    Click="ClearHistoryButton_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="#24FFFFFF"/>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="62"/>
                        <RowDefinition Height="1"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Margin="16,13">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="#FF2C2C2E"
                                BorderBrush="#665A5A5F"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="11,0"
                                Margin="0,0,9,0">
                            <Grid>
                                <TextBlock x:Name="SearchPlaceholder"
                                           Text="Search players and messages"
                                           Foreground="#78EBEBF5"
                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                           FontSize="12"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"/>
                                <TextBox x:Name="SearchBox"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="#FFF5F5F7"
                                         CaretBrush="#FF0A84FF"
                                         FontFamily="Segoe UI Variable Text, Segoe UI"
                                         FontSize="12"
                                         VerticalContentAlignment="Center"
                                         TextChanged="SearchBox_TextChanged"/>
                            </Grid>
                        </Border>

                        <ComboBox x:Name="ChannelFilter"
                                  Grid.Column="1"
                                  Style="{StaticResource FilterCombo}"
                                  SelectionChanged="Filter_SelectionChanged"/>
                        <ComboBox x:Name="LanguageFilter"
                                  Grid.Column="2"
                                  Style="{StaticResource FilterCombo}"
                                  Margin="9,0,0,0"
                                  SelectionChanged="Filter_SelectionChanged"/>
                        <ToggleButton x:Name="FavoritesFilter"
                                      Grid.Column="3"
                                      Width="40"
                                      Height="34"
                                      Margin="9,0,0,0"
                                      Background="#FF2C2C2E"
                                      Foreground="#FFFFCC00"
                                      BorderBrush="#665A5A5F"
                                      BorderThickness="1"
                                      FontSize="18"
                                      Cursor="Hand"
                                      ToolTip="Favorites only"
                                      Checked="Filter_SelectionChanged"
                                      Unchecked="Filter_SelectionChanged"
                                      Content="&#x2606;"/>
                    </Grid>

                    <Border Grid.Row="1" Background="#24FFFFFF"/>

                    <Grid Grid.Row="2">
                        <ListBox x:Name="MessageList"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="20,14,20,18"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Hidden"
                                 SelectionChanged="MessageList_SelectionChanged">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,13"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="MessageSurface"
                                                        Background="Transparent"
                                                        CornerRadius="8"
                                                        Padding="8">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="MessageSurface" Property="Background" Value="#1AFFFFFF"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="MessageSurface" Property="Background" Value="#220A84FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel MaxWidth="620" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal" Margin="10,0,0,4">
                                                <TextBlock Text="{Binding Player}"
                                                           Foreground="#B8EBEBF5"
                                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding DisplayTime}"
                                                           Foreground="#72EBEBF5"
                                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                                           FontSize="10"
                                                           Margin="8,0,0,0"/>
                                                <TextBlock Text="{Binding Channel}"
                                                           Foreground="#72EBEBF5"
                                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                                           FontSize="10"
                                                           Margin="8,0,0,0"/>
                                            </StackPanel>

                                            <Border Background="#FF3A3A3C"
                                                    CornerRadius="18"
                                                    Padding="13,8"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding OriginalText}"
                                                           Foreground="#FFF5F5F7"
                                                           FontFamily="Segoe UI Variable Text, Segoe UI"
                                                           FontSize="14"
                                                           TextWrapping="Wrap"/>
                                            </Border>

                                            <Border Background="#D92C2C2E"
                                                    BorderBrush="#365A5A5F"
                                                    BorderThickness="1"
                                                    CornerRadius="16"
                                                    Padding="12,7"
                                                    HorizontalAlignment="Left"
                                                    Margin="10,5,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasTranslation}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding LanguageLabel}"
                                                               Foreground="#FF64D2FF"
                                                               FontFamily="Segoe UI Variable Text, Segoe UI"
                                                               FontSize="9"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TranslatedText}"
                                                               Foreground="#EAF5F5F7"
                                                               FontFamily="Segoe UI Variable Text, Segoe UI"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>

                                            <Border Background="#FF0A84FF"
                                                    CornerRadius="18"
                                                    Padding="13,8"
                                                    HorizontalAlignment="Right"
                                                    Margin="70,8,0,0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasReply}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding ReplyTranslatedText}"
                                                               Foreground="White"
                                                               FontFamily="Segoe UI Variable Text, Segoe UI"
                                                               FontSize="13"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding ReplyText}"
                                                               Foreground="#CFFFFFFF"
                                                               FontFamily="Segoe UI Variable Text, Segoe UI"
                                                               FontSize="10"
                                                               TextWrapping="Wrap"
                                                               Margin="0,3,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Margin="12,16,0,0">
                                            <Button Content="{Binding FavoriteGlyph}"
                                                    Tag="{Binding}"
                                                    Width="28" Height="28"
                                                    Background="#FF2C2C2E"
                                                    Foreground="#FFFFCC00"
                                                    FontSize="16"
                                                    Style="{StaticResource CircleButton}"
                                                    ToolTip="Toggle favorite"
                                                    Click="FavoriteButton_Click"/>
                                            <Button Content="&#x00D7;"
                                                    Tag="{Binding}"
                                                    Width="28" Height="28"
                                                    Margin="0,6,0,0"
                                                    Background="#FF2C2C2E"
                                                    Foreground="#99EBEBF5"
                                                    FontSize="15"
                                                    Style="{StaticResource CircleButton}"
                                                    ToolTip="Delete message"
                                                    Click="DeleteMessageButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel x:Name="EmptyState"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    IsHitTestVisible="False">
                            <Border Width="44" Height="44" Background="#FF2C2C2E" CornerRadius="22">
                                <TextBlock Text="&#x2026;" Foreground="#FF0A84FF" FontSize="28"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Margin="0,-8,0,0"/>
                            </Border>
                            <TextBlock Text="No messages found"
                                       Foreground="#B8EBEBF5"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Margin="0,10,0,0"/>
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="3"
                            Background="#F5222224"
                            BorderBrush="#24FFFFFF"
                            BorderThickness="0,1,0,0"
                            Padding="16,12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="ReplyContextText"
                                       Text="Select a message to reply"
                                       Foreground="#8FEBEBF5"
                                       FontFamily="Segoe UI Variable Text, Segoe UI"
                                       FontSize="11"
                                       Margin="4,0,0,7"/>

                            <Border Grid.Row="1"
                                    Background="#FF2C2C2E"
                                    BorderBrush="#665A5A5F"
                                    BorderThickness="1"
                                    CornerRadius="22"
                                    Padding="14,5,5,5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Grid>
                                        <TextBlock x:Name="HistoryReplyPlaceholder"
                                                   Text="Message"
                                                   Foreground="#78EBEBF5"
                                                   FontFamily="Segoe UI Variable Text, Segoe UI"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                        <TextBox x:Name="HistoryReplyBox"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="#FFF5F5F7"
                                                 CaretBrush="#FF0A84FF"
                                                 FontFamily="Segoe UI Variable Text, Segoe UI"
                                                 FontSize="14"
                                                 VerticalContentAlignment="Center"
                                                 IsEnabled="False"
                                                 TextChanged="HistoryReplyBox_TextChanged"
                                                 PreviewKeyDown="HistoryReplyBox_PreviewKeyDown"/>
                                    </Grid>

                                    <Button x:Name="HistorySendButton"
                                            Grid.Column="1"
                                            Width="32" Height="32"
                                            Margin="8,0,0,0"
                                            Background="#FF0A84FF"
                                            Foreground="White"
                                            FontSize="20"
                                            FontWeight="Bold"
                                            Style="{StaticResource CircleButton}"
                                            ToolTip="Translate and copy"
                                            IsEnabled="False"
                                            Click="HistorySendButton_Click"
                                            Content="&#x2191;"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
