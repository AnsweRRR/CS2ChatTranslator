<Window x:Class="CS2ChatTranslator.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CS2 Chat Translator"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="480"
        SizeToContent="Height">

    <StackPanel>

        <!-- Drag mód sáv – csak drag módban látható -->
        <Border x:Name="DragHandle"
                Visibility="Collapsed"
                Background="#DD1a1a2e"
                CornerRadius="4,4,0,0"
                Padding="8,6"
                Cursor="SizeAll"
                MouseLeftButtonDown="DragBorder_MouseLeftButtonDown">
            <Grid>
                <TextBlock Text="⠿  Húzd ide az áthelyezéshez"
                           Foreground="#CCFFFFFF"
                           FontSize="12"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Ctrl+Shift+D = kilépés drag módból"
                           Foreground="#88FFFFFF"
                           FontSize="10"
                           FontFamily="Consolas"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Üzenetek -->
        <StackPanel x:Name="MessagePanel" Margin="0,0,0,4"/>

        <!-- Drag mód hint – csak normál módban, halványan -->
        <Border x:Name="HintPanel"
                Visibility="Collapsed"
                Background="#661a1a2e"
                CornerRadius="4"
                Padding="6,3"
                Margin="0,2,0,0">
            <TextBlock Text="Ctrl+Shift+D = mozgatás"
                       Foreground="#66FFFFFF"
                       FontSize="10"
                       FontFamily="Consolas"
                       HorizontalAlignment="Center"/>
        </Border>

    </StackPanel>
</Window>
